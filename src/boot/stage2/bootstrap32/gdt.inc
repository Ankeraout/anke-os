align 8
gdt:
    .null   times 8 db 0
    .cs32   db 0xff, 0xff, 0x00, 0x00, 0x00, 0x9b, 0xcf, 0x00
    .ds32   db 0xff, 0xff, 0x00, 0x00, 0x00, 0x93, 0xcf, 0x00
    .cs64   db 0xff, 0xff, 0x00, 0x00, 0x00, 0x9b, 0xaf, 0x00
    .ds64   db 0xff, 0xff, 0x00, 0x00, 0x00, 0x93, 0xaf, 0x00
    .end:

gdtr:
    .size dw gdt.end - gdt - 1
    .base dd gdt

gdt_init:
    lgdt [gdtr]
    
    mov ax, 0x0010
    mov ds, ax
    mov es, ax
    mov fs, ax
    mov gs, ax
    mov ss, ax
    
    jmp dword 0x0008:.next

.next:
    ret
